-- ---- Fire -----------------------------------------------------------
local function qbDoThrow(dir,pwr)
    if not qbEnabled or qb_throwCooldown then return end
    local F=Char and Char:FindFirstChildOfClass("Tool"); if not F then return end
    local h=F:FindFirstChild("Handle") or F:FindFirstChildOfClass("BasePart")
    if not h then return end
    local R = h:FindFirstChildOfClass("RemoteEvent")
    if not R then R = F:FindFirstChildOfClass("RemoteEvent") end
    if not R then R = F:FindFirstChild("RemoteEvent",true) end
    if not R then return end
    pcall(function() h.CanCollide=false end)
    pcall(function()
        local a=RS:FindFirstChild("Animations"); local ta=a and a:FindFirstChild("Throw")
        if ta then Char.Humanoid:LoadAnimation(ta):Play() end
    end)
    qb_throwCooldown = true
    task.delay(0.13, function()
        if not h or not h.Parent then qb_throwCooldown = false; return end
        local origin = h.Position
        local target = origin + dir * 10000
        if game.PlaceId == 8206123457 then
            pcall(function() R:FireServer("Clicked", origin, target, pwr) end)
        else
            local ok = pcall(function() R:FireServer("Clicked", origin, target, 1, pwr) end)
            if not ok then pcall(function() R:FireServer("Clicked", origin, target, pwr) end) end
        end
        task.delay(0.25, function()
            pcall(function() if h and h.Parent then h.CanCollide=true end end)
        end)
        task.delay(0.4, function() qb_throwCooldown = false end)
    end)
end

local function qbExec()
    if not qbEnabled or qb_throwCooldown then return end
    -- Try to auto-pick a target if none selected yet (important for mobile)
    if not qb_data.target then
        qb_receivers = qbBuildReceiverList()
        if #qb_receivers > 0 then
            qb_data.target = qb_receivers[1].char
        else
            return
        end
    end
    if not qbHasBall() then return end
    local head=Char and Char:FindFirstChild("Head")
    if not head then return end

    -- Always solve fresh at fire time with latest smoothed velocity
    local hrp=qb_data.target:FindFirstChild("HumanoidRootPart")
    local tPos=hrp and hrp.Position or qb_data.target:GetPivot().Position

    local pwr,ang,air,pred=qbCalc(head.Position,tPos,qb_data.smoothVel,qb_autoAngle,qb_mode)

    if not pwr or pwr<=0 then return end

    -- Power: if Auto Power ON use physics-solved, else read BallGui Disp label
    local guiPwr = nil
    if not qb_autoPower then
        local ballGui = Player.PlayerGui:FindFirstChild("BallGui")
        if ballGui then
            local ok, d = pcall(function() return ballGui:FindFirstChild("Disp", true) end)
            if ok and d and d:IsA("TextLabel") then guiPwr = tonumber(d.Text) end
        end
    end
    local firePwr = (not qb_autoPower and guiPwr) or pwr

    -- Build throw direction from solved physics
    local pm=qb_PM[qb_mode] or qb_PM["Dime"]
    local g=qb_gMag*pm[3]
    local gv=Vector3.new(0,-g,0)
    local toP=pred-head.Position
    if toP.Magnitude<0.1 then return end
    local x0=head.Position+toP.Unit*4
    -- direction = displacement minus gravity arc
    local dir=pred-x0-0.5*gv*air*air
    if dir.Magnitude<0.1 then return end
    qbDoThrow(dir.Unit,firePwr)
end

local function qbCycle(rev)
    if rev then qb_idx=qb_idx-1; if qb_idx<1 then qb_idx=#qb_types end
    else qb_idx=qb_idx+1; if qb_idx>#qb_types then qb_idx=1 end end
    qb_mode=qb_types[qb_idx]; qbS(qb_modeL,qb_mode)
end

