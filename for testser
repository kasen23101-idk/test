RunService.RenderStepped:Connect(function(dt)
    if not qbEnabled then
        qb_beam.Enabled=false; qbHL.Enabled=false; qb_gui.Enabled=false; return end
    if not qbHasBall() then
        qb_beam.Enabled=false; qbHL.Enabled=false; qb_gui.Enabled=false; qb_data.target=nil; return end
    qb_gui.Enabled=true

    -- Target tracking
    if qb_lockedPlayer then
        local nc=qb_lockedPlayer.Character
        if nc and nc.Parent then
            if qb_lockedTarget~=nc then
                qb_lockedTarget=nc; qb_data.target=nc
                qbHL.Adornee=nc; qbHL.Enabled=true
                qb_data.smoothVel=Vector3.new(); qb_data.prevVel=Vector3.new(); qbHistClear()
            else qb_data.target=qb_lockedTarget end
        else
            qb_data.target=nil; qb_beam.Enabled=false; qbS(qb_tgtL,"L:(wait)"); return
        end
    else
        -- Rebuild sorted receiver list every frame so cycling is always fresh
        qb_receivers=qbBuildReceiverList()
        qbGetTarget()
    end

    if not qb_data.target or not qb_data.target.Parent then
        qbHL.Enabled=false; qb_beam.Enabled=false
        qbS(qb_angL,"--"); qbS(qb_modeL,qb_mode); qbS(qb_airL,"--"); qbS(qb_powerL,"--"); qbS(qb_tgtL,"None")
        return
    end

    qbHL.Adornee=qb_data.target; qbHL.Enabled=true
    local head=Char:FindFirstChild("Head"); if not head then return end

    local hrp=qb_data.target:FindFirstChild("HumanoidRootPart")
    local tPos=hrp and hrp.Position or qb_data.target:GetPivot().Position
    local tVel=hrp and hrp.AssemblyLinearVelocity or Vector3.new()

    -- Push to history for future use
    qbHistPush(tPos, tick())

    -- Adaptive EMA velocity smoothing
    local velDelta=(tVel-qb_data.prevVel).Magnitude
    local alpha = math.clamp(0.07 + velDelta*0.25, 0.07, 0.40)
    qb_data.smoothVel=qb_data.smoothVel:Lerp(tVel,alpha)
    qb_data.prevVel=tVel

    local cv,ang,air=qbCalc(head.Position,tPos,qb_data.smoothVel,qb_autoAngle,qb_mode)
    qb_data.power=cv; qb_data.angle=ang; qb_data.airtime=air

    -- HUD
    local tp=Players:GetPlayerFromCharacter(qb_data.target)
    local tn=tp and (tp.DisplayName~="" and tp.DisplayName or tp.Name) or "NPC"
    -- show index/total so you know how many receivers there are
    local total=#qb_receivers
    local idx=1
    for i,r in ipairs(qb_receivers) do if r.char==qb_data.target then idx=i;break end end
    local suffix=total>1 and (" "..idx.."/"..total) or ""
    if qb_lockedPlayer or qb_manualTarget then tn=">"..tn end
    tn=tn..suffix

    local dp=string.format("%d",math.floor((cv or 0)+0.5))

    qbS(qb_angL,string.format("%.1f",ang).."d")
    qbS(qb_modeL,qb_mode)
    qbS(qb_airL,string.format("%.2f",air).."s")
    qbS(qb_powerL,dp)
    qbS(qb_tgtL,tn)

    -- Arc beam
    if air>0 and cv>0 then
        local pm2=qb_PM[qb_mode] or qb_PM["Dime"]
        local gv=Vector3.new(0,-qb_gMag*pm2[3],0)
        local tt=qb_data.targetPos-head.Position
        if tt.Magnitude>0.01 then
            local x0=head.Position+tt.Unit*3
            local du=qb_data.targetPos-x0-0.5*gv*air*air
            if du.Magnitude>0.01 then
                du=du.Unit
                local c0,c1,cf1,cf2=beamProj(gv,du*cv,x0,air)
                qb_beam.Enabled=true
                qb_beam.CurveSize0=c0 or 0; qb_beam.CurveSize1=c1 or 0
                qba0.CFrame=qba0.Parent.CFrame:Inverse()*(cf1 or CFrame.new(x0))
                qba1.CFrame=qba1.Parent.CFrame:Inverse()*(cf2 or CFrame.new(qb_data.targetPos))
            end
        end
    else
        qb_beam.Enabled=false
    end
end)

UIS.InputBegan:Connect(function(inp,gpe)
    if gpe or not qbEnabled then return end
    local kc=inp.KeyCode; local ut=inp.UserInputType
    -- Throw type cycle: Z=forward, X=backward
    if kc==Enum.KeyCode.Z then qbCycle(false) end
    if kc==Enum.KeyCode.X then qbCycle(true) end
    -- Lock/unlock target: F
    if kc==Enum.KeyCode.F then
        if qb_manualTarget or qb_lockedPlayer or qb_lockedTarget then qbUnlock() else qbLock() end
    end
    -- Cycle receivers: R=next, G=prev
    if kc==Enum.KeyCode.R then qbCycleTarget(false) end
    if kc==Enum.KeyCode.G then qbCycleTarget(true) end
    -- Throw: Space or M1
    if kc==Enum.KeyCode.Space then qbExec() end
    if ut==Enum.UserInputType.MouseButton1 and qbHasBall() then qbExec() end
    -- Controller
    if ut==Enum.UserInputType.Gamepad1 then
        if kc==Enum.KeyCode.ButtonR2 then qbExec() end
        if kc==Enum.KeyCode.ButtonR1 or kc==Enum.KeyCode.DPadRight then qbCycle(false) end
        if kc==Enum.KeyCode.ButtonL1 or kc==Enum.KeyCode.DPadLeft  then qbCycle(true) end
        if kc==Enum.KeyCode.DPadUp then qbCycleTarget(false) end
        if kc==Enum.KeyCode.DPadDown then qbCycleTarget(true) end
        if kc==Enum.KeyCode.ButtonB then
            if qb_manualTarget or qb_lockedPlayer or qb_lockedTarget then qbUnlock() else qbLock() end
        end
    end
end)

