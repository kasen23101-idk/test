-- Cycle to next/prev receiver
local function qbCycleTarget(rev)
    if #qb_receivers==0 then
        -- rebuild once immediately
        qb_receivers=qbBuildReceiverList()
        if #qb_receivers==0 then return end
    end
    -- find current target in list
    if qb_data.target and not qb_manualTarget then
        for i,r in ipairs(qb_receivers) do
            if r.char==qb_data.target then qb_tgtIdx=i; break end
        end
    end
    qbSetTargetIdx(qb_tgtIdx+(rev and -1 or 1))
end

local function qbGetTarget()
    -- if user manually picked a target, keep it (unless it died/left)
    if qb_manualTarget and qb_lockedTarget then
        local h=qb_lockedTarget:FindFirstChild("HumanoidRootPart")
        local hum=qb_lockedTarget:FindFirstChild("Humanoid")
        if h and qb_lockedTarget.Parent and (not hum or hum.Health>0) then
            qb_data.target=qb_lockedTarget; return
        else
            -- target gone, fall through to auto
            qb_lockedTarget=nil; qb_lockedPlayer=nil; qb_manualTarget=false
        end
    end
    if qb_lockedTarget then
        local h=qb_lockedTarget:FindFirstChild("HumanoidRootPart")
        if h and qb_lockedTarget.Parent then qb_data.target=qb_lockedTarget; return
        else qb_lockedTarget=nil end
    end
    -- auto: pick best from list
    if #qb_receivers>0 then
        local best=qb_receivers[1]
        if best and best.char~=qb_data.target then
            qb_data.target=best.char
            qbHL.Adornee=best.char; qbHL.Enabled=qbEnabled
            qb_data.smoothVel=Vector3.new(); qb_data.prevVel=Vector3.new(); qbHistClear()
        end
    end
end

local function qbLock()
    if not qb_data.target then
        qb_receivers = qbBuildReceiverList()
        if #qb_receivers > 0 then
            qb_data.target = qb_receivers[1].char
        else return end
    end
    local tp=Players:GetPlayerFromCharacter(qb_data.target)
    if tp then qb_lockedPlayer=tp; qb_lockedTarget=qb_data.target
    else qb_lockedPlayer=nil; qb_lockedTarget=qb_data.target end
    local nm=(tp and (tp.DisplayName~="" and tp.DisplayName or tp.Name)) or qb_data.target.Name or "?"
    -- find index in receiver list
    local idx,total=1,#qb_receivers
    for i,r in ipairs(qb_receivers) do if r.char==qb_data.target then idx=i;break end end
    qbS(qb_tgtL,"L:"..nm..(total>0 and " "..idx.."/"..total or ""))
    qb_manualTarget=true
end
