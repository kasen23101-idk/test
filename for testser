Library:OnUnload(function()
    magson = false; autocatchon = false; speedEnabled = false
    pullvector = false; jumpoweron = false; nojpcooldownon = false
    clicktackleon = false; ballpathOn = false; deleteOOBEnabled = false
    trajEnabled = false; qbEnabled = false

    removeHitboxes()

    if Char then
        local cl = Char:FindFirstChild("CatchLeft");  if cl then cl.Size = Vector3.new(0.75,5,1.5) end
        local cr = Char:FindFirstChild("CatchRight"); if cr then cr.Size = Vector3.new(0.75,5,1.5) end
    end

    for _, conn in pairs(njcconnections) do if conn then conn:Disconnect() end end
    njcconnections = {}

    stopMovementSystem()
    perfBeam_stop()

    if ballpathConnection then ballpathConnection:Disconnect() end

    for _, obj in ipairs(Workspace.Terrain:GetChildren()) do
        if obj:IsA("Beam") and (obj.Name == "BallPath"
            or obj.Name == "PerfHitbox"
            or obj.Name == "TrajHitbox") then obj:Destroy()
        elseif obj:IsA("Attachment") and obj.Name == "BallPathAtt" then obj:Destroy() end
    end

    qb_beam.Enabled = false; traj_beam.Enabled = false
    qb_HL.Enabled   = false; qb_gui.Enabled = false
    qb_lockedTarget = nil; qb_throwCooldown = false
end)

      
