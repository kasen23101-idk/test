-- PAGE + TAB SYSTEM
local pages = {}
local tabBtns = {}

local function newPage(name)
    local s = Instance.new("ScrollingFrame")
    s.Name = name
    s.Size = UDim2.new(1, 0, 1, 0)
    s.BackgroundTransparency = 1
    s.BorderSizePixel = 0
    s.ScrollBarThickness = 3
    s.ScrollBarImageColor3 = Color3.fromRGB(180, 30, 30)
    s.CanvasSize = UDim2.new(0,0,0,0)
    s.AutomaticCanvasSize = Enum.AutomaticSize.Y
    s.Visible = false
    s.ZIndex = 2
    s.Parent = content
    local l = Instance.new("UIListLayout"); l.Padding=UDim.new(0,3); l.Parent=s
    local p = Instance.new("UIPadding"); p.PaddingTop=UDim.new(0,6); p.PaddingLeft=UDim.new(0,8); p.PaddingRight=UDim.new(0,8); p.Parent=s
    pages[name] = s
    return s
end

local function switchTab(name)
    for _, pg in pairs(pages) do pg.Visible = false end
    for _, tb in pairs(tabBtns) do
        tb.BackgroundColor3 = Color3.fromRGB(22, 8, 8)
        tb.TextColor3 = Color3.fromRGB(110, 40, 40)
        local stroke = tb:FindFirstChildOfClass("UIStroke")
        if stroke then stroke.Color = Color3.fromRGB(70, 20, 20) end
    end
    if pages[name] then pages[name].Visible = true end
    if tabBtns[name] then
        tabBtns[name].BackgroundColor3 = Color3.fromRGB(170, 20, 20)
        tabBtns[name].TextColor3 = Color3.fromRGB(255, 200, 200)
        local stroke = tabBtns[name]:FindFirstChildOfClass("UIStroke")
        if stroke then stroke.Color = Color3.fromRGB(255, 60, 60) end
    end
end

