local aimbotActive, aimbotSmooth, aimbotConn = false, 5, nil
local function getNearest()
    local cam=workspace.CurrentCamera; local closest,dist=nil,math.huge
    local center=Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=lp and p.Character then
            local head=p.Character:FindFirstChild("Head")
            local hum=p.Character:FindFirstChildOfClass("Humanoid")
            if head and hum and hum.Health>0 then
                local sp,on=cam:WorldToScreenPoint(head.Position)
                if on then local d=(Vector2.new(sp.X,sp.Y)-center).Magnitude; if d<dist then dist=d; closest=head end end
            end
        end
    end
    return closest
end
local function startAimbot()
    if aimbotConn then aimbotConn:Disconnect(); aimbotConn=nil end
    aimbotConn=RS.Heartbeat:Connect(function()
        if not aimbotActive then return end
        local target=getNearest(); if not target then return end
        local cam=workspace.CurrentCamera
        local torso=target.Parent and (target.Parent:FindFirstChild("HumanoidRootPart") or target.Parent:FindFirstChild("UpperTorso") or target.Parent:FindFirstChild("Torso"))
        local aim=torso or target
        local sp,on=cam:WorldToScreenPoint(aim.Position)
        if not on then return end
        local center=Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
        local delta=Vector2.new(sp.X,sp.Y)-center
        mousemoverel(delta.X/math.max(aimbotSmooth,1), delta.Y/math.max(aimbotSmooth,1))
    end)
end
local function stopAimbot()
    aimbotActive=false; if aimbotConn then aimbotConn:Disconnect(); aimbotConn=nil end
end
 
