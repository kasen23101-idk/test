-- ================================================================
-- KICKER AIMBOT v3
-- Strategy: monitor ALL bar-like elements for the one that's actively
-- animating (value changing frame-to-frame). Click when threshold hit.
-- Supports Position.Y.Scale, Size.Y.Scale, and AbsolutePosition.Y
-- ================================================================
local kickerAutoEnabled = false
local kickerPower = 95
local kickerAcc   = 75

-- ================================================================
-- KICKER AIMBOT (ported from confirmed working Aethel reference)
-- FF2 KickerGui has a "Cursor" child whose Position.Y.Scale sweeps
-- from 0->1 during each phase. We click at power/accuracy thresholds.
-- ================================================================
local function handleKickerGui(child)
    if child.Name ~= "KickerGui" or not kickerAutoEnabled then return end
    task.spawn(function()
        -- Wait for Cursor to exist (up to 5s)
        local cursor
        local deadline = tick() + 5
        repeat
            cursor = child:FindFirstChild("Cursor", true)
            task.wait()
        until cursor or tick() > deadline
        if not cursor then return end

        -- Phase 1: Power -- click when cursor.Y.Scale reaches power threshold
        -- Low threshold = click early = less power; high = more power
        local powerThreshold = 0.01 + ((100 - kickerPower) * 0.012)
        repeat task.wait() until not child.Parent
            or cursor.Position.Y.Scale >= powerThreshold
        if not child.Parent then return end

        local cx = Camera.ViewportSize.X / 2
        local cy = Camera.ViewportSize.Y / 2
        VIM:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
        task.wait(0.05)
        VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)

        -- Phase 2: Accuracy -- wait, then click when cursor reaches accuracy threshold
        task.wait(0.15)
        local accThreshold = 0.9 - ((100 - kickerAcc) * 0.001)
        repeat task.wait() until not child.Parent
            or cursor.Position.Y.Scale >= accThreshold
        if not child.Parent then return end

        VIM:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
        task.wait(0.05)
        VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
    end)
end

Player:WaitForChild("PlayerGui").ChildAdded:Connect(function(child)
    if kickerAutoEnabled then handleKickerGui(child) end
end)

