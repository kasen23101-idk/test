local function tryAdminCode()
    task.spawn(function()
        if adminCodeBox.Text == ADMIN_CODE then
            adminStatus.Text = "✓ ACCESS GRANTED"
            adminStatus.TextColor3 = Color3.fromRGB(60, 220, 120)
            lockIcon.Text = "🔓"
            TS:Create(adminLockFrame, TweenInfo.new(0.4, Enum.EasingStyle.Sine), {BackgroundColor3=Color3.fromRGB(6,14,8)}):Play()
            task.wait(0.6)
            TS:Create(adminLockFrame, TweenInfo.new(0.3), {BackgroundTransparency=1}):Play()
            for _, ch in ipairs(adminLockFrame:GetChildren()) do
                if ch:IsA("GuiObject") then
                    TS:Create(ch, TweenInfo.new(0.3), {BackgroundTransparency=1, TextTransparency=1}):Play()
                end
            end
            task.wait(0.35)
            adminLockFrame:Destroy()
            adminUnlocked = true
        else
            adminStatus.Text = "✗ WRONG CODE"
            adminStatus.TextColor3 = Color3.fromRGB(255, 60, 60)
            -- Shake
            local origPos = adminCodeBox.Position
            for i = 1, 4 do
                TS:Create(adminCodeBox, TweenInfo.new(0.04), {Position=UDim2.new(0.5,-72,0,124)}):Play()
                task.wait(0.04)
                TS:Create(adminCodeBox, TweenInfo.new(0.04), {Position=UDim2.new(0.5,-88,0,124)}):Play()
                task.wait(0.04)
            end
            TS:Create(adminCodeBox, TweenInfo.new(0.04), {Position=origPos}):Play()
            task.wait(1.2)
            adminStatus.Text = ""
        end
    end)
end
 
