local function makeDragCard(gui, name, anchorX, anchorY, offsetX, offsetY, defaultTxt, titleTxt, color)
    color = color or Color3.fromRGB(100, 105, 231)
    local frame = Instance.new("Frame")
    frame.Name              = name
    frame.Parent            = gui
    frame.Size              = UDim2.new(0, CARD_W, 0, CARD_H)
    frame.AnchorPoint       = Vector2.new(anchorX, anchorY)
    frame.Position          = UDim2.new(anchorX, offsetX, anchorY, offsetY)
    frame.BackgroundColor3  = Color3.fromRGB(18, 18, 24)
    frame.BorderSizePixel   = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = color; stroke.Thickness = 1.5; stroke.Transparency = 0.4

    local vLabel = Instance.new("TextLabel")
    vLabel.Parent             = frame
    vLabel.Size               = UDim2.new(1,-4,0.62,0)
    vLabel.Position           = UDim2.new(0,2,0,6)
    vLabel.BackgroundTransparency = 1
    vLabel.Text               = defaultTxt
    vLabel.TextColor3         = color
    vLabel.TextScaled         = false
    vLabel.TextSize           = CARD_FONT_BIG
    vLabel.Font               = Enum.Font.GothamBold
    vLabel.TextStrokeTransparency = 0.4

    local tLabel = Instance.new("TextLabel")
    tLabel.Parent             = frame
    tLabel.Size               = UDim2.new(1,-4,0.3,0)
    tLabel.Position           = UDim2.new(0,2,0.68,0)
    tLabel.BackgroundTransparency = 1
    tLabel.Text               = titleTxt
    tLabel.TextColor3         = Color3.fromRGB(160, 160, 175)
    tLabel.TextScaled         = false
    tLabel.TextSize           = CARD_FONT_SMALL
    tLabel.Font               = Enum.Font.Gotham

    -- Drag logic (works with both mouse and touch)
    local dragging, dragStart, startPos = false, nil, nil
    frame.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
           or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = inp.Position; startPos = frame.Position
            inp.Changed:Connect(function()
                if inp.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
           or inp.UserInputType == Enum.UserInputType.Touch then
            local d = inp.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X,
                                       startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
           or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    return vLabel
end

