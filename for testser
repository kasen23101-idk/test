-- Color cycle: smoothly shifts UI between deep red and near-black
local colorTargets = {
    {frame=Color3.fromRGB(10,6,6),   border=Color3.fromRGB(220,30,30),  title=Color3.fromRGB(255,55,55),   accent=Color3.fromRGB(255,40,40)},
    {frame=Color3.fromRGB(6,6,6),    border=Color3.fromRGB(80,10,10),   title=Color3.fromRGB(160,30,30),   accent=Color3.fromRGB(120,15,15)},
    {frame=Color3.fromRGB(10,6,6),   border=Color3.fromRGB(220,30,30),  title=Color3.fromRGB(255,55,55),   accent=Color3.fromRGB(255,40,40)},
}
local colorIdx = 1
local function cycleColor()
    while true do
        colorIdx = (colorIdx % #colorTargets) + 1
        local t = colorTargets[colorIdx]
        local ti = TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
        TS:Create(frame, ti, {BackgroundColor3 = t.frame}):Play()
        local bs = frame:FindFirstChildOfClass("UIStroke")
        if bs then TS:Create(bs, ti, {Color = t.border}):Play() end
        -- corner accents
        for _, ch in ipairs(frame:GetChildren()) do
            if ch:IsA("Frame") and ch.BackgroundColor3 == Color3.fromRGB(255,40,40) then
                TS:Create(ch, ti, {BackgroundColor3 = t.accent}):Play()
            end
        end
        -- title
        if titleBar then
            TS:Create(titleBar, ti, {BackgroundColor3 = Color3.fromRGB(
                math.floor(t.frame.R*255*1.8),
                math.floor(t.frame.G*255),
                math.floor(t.frame.B*255)
            )}):Play()
            local titleAccentF = titleBar:FindFirstChild("Frame")
            if titleAccentF then TS:Create(titleAccentF, ti, {BackgroundColor3 = t.accent}):Play() end
        end
        if titleLbl then TS:Create(titleLbl, ti, {TextColor3 = t.title}):Play() end
        task.wait(3)
    end
end
