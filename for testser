    local function tryKey()
        local key = box.Text:match("^%s*(.-)%s*$"):upper()
        if key=="" then
            status.TextColor3=Color3.fromRGB(220,80,80)
            status.Text="Enter a key first."
            return
        end

        local keyDef = KEYS[key]
        if not keyDef then
            status.TextColor3=Color3.fromRGB(220,80,80)
            status.Text="Invalid key."
            timeLabel.Text=""
            shake()
            return
        end

        -- Load saved activations
        local acts = loadActivations()
        local n = now()

        if acts[key] then
            -- Key was used before - check if still valid
            local expiresAt = acts[key]
            local secondsLeft = expiresAt - n
            if secondsLeft > 0 then
                acceptKey(keyDef, secondsLeft)
            else
                -- Expired
                acts[key] = nil
                saveActivations(acts)
                status.TextColor3=Color3.fromRGB(220,160,40)
                status.Text="Key expired. Purchase a renewal."
                timeLabel.TextColor3=Color3.fromRGB(150,100,30)
                timeLabel.Text=keyDef.label.." key"
                shake()
            end
        else
            -- First use - activate now, stamp expiry
            local expiresAt = n + daysToSec(keyDef.days)
            acts[key] = expiresAt
            saveActivations(acts)
            acceptKey(keyDef, daysToSec(keyDef.days))
        end
    end

