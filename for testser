local function tryKey()
    task.spawn(function()
        local entered = keyBox.Text
        if entered == VALID_KEY then
            kplay(ksndUnlock)
            keyStatus.Text = "✓ KEY ACCEPTED"
            keyStatus.TextColor3 = Color3.fromRGB(60, 220, 120)
            TS:Create(keyFrame, TweenInfo.new(0.4), {BackgroundColor3=Color3.fromRGB(6,14,8)}):Play()
            task.wait(0.7)
            TS:Create(keyFrame, TweenInfo.new(0.25), {
                Size=UDim2.new(0,320,0,0),
                Position=UDim2.new(0.5,-160,0.5,0)
            }):Play()
            task.wait(0.3)
            keyGui:Destroy()
            keyUnlocked = true
            loadMainGui()
        else
            kplay(ksndDeny)
            keyStatus.Text = "✗ INVALID KEY"
            keyStatus.TextColor3 = Color3.fromRGB(255, 60, 60)
            -- Shake animation
            local origPos = keyBox.Position
            for i = 1, 4 do
                TS:Create(keyBox, TweenInfo.new(0.04), {Position=UDim2.new(0,15+8,0,74)}):Play()
                task.wait(0.04)
                TS:Create(keyBox, TweenInfo.new(0.04), {Position=UDim2.new(0,15-8,0,74)}):Play()
                task.wait(0.04)
            end
            TS:Create(keyBox, TweenInfo.new(0.04), {Position=origPos}):Play()
            task.wait(1.2)
            keyStatus.Text = ""
        end
    end)
end

