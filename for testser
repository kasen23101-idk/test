local function qbScreenD(wp)
    local sp,on=Camera:WorldToViewportPoint(wp)
    if not on then return math.huge end
    return (Vector2.new(sp.X,sp.Y)-Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)).Magnitude
end

-- Build sorted list of all eligible receivers (teammates + bots), best first
-- Returns array of {char=model, name=string, score=number}
local function qbBuildReceiverList()
    if not Hrp then return {} end
    local list={}
    local function add(m)
        local h=m:FindFirstChild("HumanoidRootPart"); if not h then return end
        local hum=m:FindFirstChild("Humanoid"); if hum and hum.Health<=0 then return end
        local screenD=qbScreenD(h.Position)
        local worldD=(Hrp.Position-h.Position).Magnitude
        local s=(screenD/600)*0.6+(worldD/200)*0.4
        local tp=Players:GetPlayerFromCharacter(m)
        local nm=(tp and (tp.DisplayName~="" and tp.DisplayName or tp.Name)) or m.Name or "?"
        table.insert(list,{char=m,name=nm,score=s})
    end
    for _,t in pairs(Players:GetPlayers()) do
        local sameTeam = Player.Team == nil or t.Team == Player.Team
        if t~=Player and sameTeam and t.Character then add(t.Character) end
    end
    local npc=WS:FindFirstChild("npcwr")
    if npc then for _,d in pairs(npc:GetDescendants()) do
        if d:IsA("Model") and (d.Name=="bot 1" or d.Name=="bot 3") then add(d) end
    end end
    table.sort(list,function(a,b) return a.score<b.score end)
    return list
end

