local trajEnabled = true

local traj_a0 = Instance.new("Attachment")
local traj_a1 = Instance.new("Attachment")
local traj_beam = Instance.new("Beam")
traj_beam.Attachment0  = traj_a0
traj_beam.Attachment1  = traj_a1
traj_beam.Color        = ColorSequence.new(Color3.fromRGB(100, 105, 231))
traj_beam.Transparency = NumberSequence.new(0)
traj_beam.Name         = "TrajHitbox"
traj_beam.Segments     = 1750
traj_beam.FaceCamera   = true
traj_beam.Enabled      = false
traj_beam.Parent       = Workspace.Terrain
traj_a0.Parent         = Workspace.Terrain
traj_a1.Parent         = Workspace.Terrain

local function trajBeamProjectile(g, v0, x0, t1)
    local c  = 0.125
    local p3 = 0.5*g*t1*t1 + v0*t1 + x0
    local p2 = p3 - (g*t1*t1 + v0*t1)/3
    local p1 = ((c*g*t1*t1 + 0.5*v0*t1 + x0 - c*(x0+p3))/(3*c)) - p2
    local curve0 = (p1 - x0).Magnitude
    local curve1 = (p2 - p3).Magnitude
    local b  = (x0 - p3).Unit
    local r1 = (p1 - x0).Unit
    local u1 = r1:Cross(b).Unit
    local r2 = (p2 - p3).Unit
    local u2 = r2:Cross(b).Unit
    b = u1:Cross(r1).Unit
    local cf1 = CFrame.new(x0.X,x0.Y,x0.Z, r1.X,u1.X,b.X, r1.Y,u1.Y,b.Y, r1.Z,u1.Z,b.Z)
    local cf2 = CFrame.new(p3.X,p3.Y,p3.Z, r2.X,u2.X,b.X, r2.Y,u2.Y,b.Y, r2.Z,u2.Z,b.Z)
    return curve0, -curve1, cf1, cf2
end

