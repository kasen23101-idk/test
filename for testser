local function addToggle(pg,lbl,callback)
    local btn=Instance.new("TextButton",pg)
    btn.BackgroundColor3=Color3.fromRGB(185,55,55); btn.BorderSizePixel=0
    btn.Size=UDim2.new(1,0,0,44); btn.Font=Enum.Font.GothamSemibold
    btn.Text=lbl..": OFF"; btn.TextColor3=Color3.fromRGB(230,230,235); btn.TextSize=13
    Instance.new("UICorner",btn).CornerRadius=UDim.new(0,4)
    local state=false
    local COL_OFF=Color3.fromRGB(185,55,55)
    local COL_OFF_HI=Color3.fromRGB(210,70,70)
    local COL_ON=Color3.fromRGB(44,130,70)
    local COL_ON_HI=Color3.fromRGB(60,160,85)
    -- Use MouseButton1Click (not Down) so ScrollingFrame doesn't eat it
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = lbl .. (state and ": ON" or ": OFF")
        TS:Create(btn, TweenInfo.new(0.18), {
            BackgroundColor3 = state and COL_ON or COL_OFF
        }):Play()
        if callback then callback(state) end
    end)
    -- Inline hover that respects current state
    btn.MouseEnter:Connect(function()
        TS:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=state and COL_ON_HI or COL_OFF_HI}):Play() end)
    btn.MouseLeave:Connect(function()
        TS:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=state and COL_ON or COL_OFF}):Play() end)
    return btn
end

