-- ---- Physics solver ------------------------------------------------
-- Given launch angle (rad), flat distance xz, height delta dy, gravity g
-- Returns launch speed, or nil if impossible
local function velForAngle(a,xz,dy,g)
    local c=math.cos(a); if math.abs(c)<0.001 then return nil end
    local num=g*xz*xz
    local den=2*c*c*(xz*math.tan(a)-dy)
    if den<=0 then return nil end
    local v2=num/den
    if v2<=0 or v2~=v2 or v2==math.huge then return nil end
    return math.sqrt(v2)
end

-- Solve best (angle,speed,airtime) for from->target given gravity scale
-- Steps 0.5 deg for fine resolution; prefers angle closest to midpoint at same score
local function solveThrow(from,target,mode)
    local pm=qb_PM[mode] or qb_PM["Dime"]
    local mn,mx,gs=pm[1],pm[2],pm[3]
    local g=qb_gMag*gs
    local disp=target-from
    local xz=Vector3.new(disp.X,0,disp.Z).Magnitude
    local dy=disp.Y
    local mid=(mn+mx)/2
    local bV,bA,bT,bScore=0,mid,0,math.huge
    local step=0.5
    for ad=mn,mx,step do
        local ar=math.rad(ad)
        local v=velForAngle(ar,xz,dy,g)
        if v and v>0 and v<=95 then
            local at=xz/(v*math.cos(ar))
            -- score: penalise high power and angles far from mid (prefer low flat throws)
            local sc=v*0.2+math.abs(ad-mid)*0.5
            if sc<bScore then bScore=sc; bA=ad; bV=v; bT=at end
        end
    end
    -- if power is still >90, walk angle up toward max to find lower power solution
    if bV>90 then
        for ad=bA,mx,step do
            local ar=math.rad(ad)
            local v=velForAngle(ar,xz,dy,g)
            if v and v>0 and v<bV then bA=ad; bV=v; bT=xz/(v*math.cos(ar)); break end
        end
    end
    bV=math.clamp(bV,0,95)
    return bV,bA,bT
end

-- ================================================================
-- qbCalc: physics-accurate lead per throw mode
--
-- Each mode has a unique lead profile:
--   Dime   - long distance, leads fully along receiver path + slight upfield bias
--   Mag    - similar to dime but allows vertical correction (over LBs)
--   Dive   - receiver diving forward, extra forward lead, no lateral
--   Jump   - receiver jumping, add upward arc bias to prediction
--   Slant  - receiver cutting across field: lead perpendicular to QB->receiver line
--   Bullet - fast flat throw: minimal lead, purely horizontal velocity-based
--   Lob    - high arc, long air time: maximum forward lead + height compensation
--   Screen - very short, receiver slowing down: reduce lead, catch behind LOS
--
-- Formula: pred = receiverPos
--            + vel * airtime               (pure velocity prediction)
--            + modeSlant * lateralVec      (mode-specific directional bias)
--            + Vector3.new(0, heightBias, 0) (vertical correction per mode)
-- ================================================================

-- Per-mode tuning: {velScale, extraLead, lateralSlant, heightBias}
-- velScale:    multiplier on velocity*airtime (1.0 = full physics, <1 = conservative)
-- extraLead:   flat extra studs in movement direction (from slider)
-- lateralSlant: bias perpendicular to QB->receiver line (+ = toward sideline)
-- heightBias:  extra Y added to prediction target
local function applyAntiOOB(pos)
    if not qb_antiOOB then return pos end
    local bb=WS:FindFirstChild("bbounds")
    if not bb then return pos end
    local p,s=bb.Position,bb.Size
    return Vector3.new(
        math.clamp(pos.X,p.X-s.X/2+2,p.X+s.X/2-2),
        pos.Y,
        math.clamp(pos.Z,p.Z-s.Z/2+2,p.Z+s.Z/2-2))
end

-- Main prediction: iterative lead compensation
-- Returns power,angle,airtime,predictedPos
local function qbCalc(from,to,vel,autoA,mode)
    local pm=qb_PM[mode] or qb_PM["Dime"]
    local _,_,gs=pm[1],pm[2],pm[3]
    local g=qb_gMag*gs
    local lead=qb_lead[mode] or 5

    local hvl=Vector3.new(vel.X,0,vel.Z)
    local hspd=hvl.Magnitude
    local hdir=hspd>0.5 and hvl.Unit or Vector3.new()

    local fl=Vector3.new((to-from).X,0,(to-from).Z).Magnitude

    -- Build a prediction given a specific airtime t
    local function buildPred(t)
        -- Velocity lead: where receiver will be in t seconds
        local velLead = hvl * t
        -- Flat slider lead: only applied when receiver is actually moving
        -- When stationary (hspd<0.5), slider lead is 0 so we don't push it forward
        local sliderLead = hdir * lead * math.clamp(hspd / 4, 0, 1)
        -- Height: aim slightly above receiver's current position scaled with distance
        -- This compensates for ball arc drop at long range
        -- At 20 studs = +0.5, at 60 studs = +1.5, at 100 studs = +2.5
        local heightComp = Vector3.new(0, math.clamp(fl * 0.025, 0.3, 3.0), 0)
        return applyAntiOOB(to + velLead + sliderLead + heightComp)
    end

    local initT = math.max(fl/40, 0.15)
    local pred  = buildPred(initT)
    local bV,bA,bT = solveThrow(from,pred,mode)

    -- Iterative refinement: 5 passes using actual solved airtime
    for _=1,5 do
        if bT>0.05 then
            local newPred = buildPred(bT)
            local nV,nA,nT = solveThrow(from,newPred,mode)
            if nV>0 and math.abs(nT-bT)<0.4 then
                pred=newPred; bV=nV; bA=nA; bT=nT
            else break end
        else break end
    end

    -- manual angle override
    if not autoA then
        local ar=math.rad(qb_manualAngle)
        local disp=pred-from
        local xz=Vector3.new(disp.X,0,disp.Z).Magnitude
        local v=velForAngle(ar,xz,disp.Y,g)
        bA=qb_manualAngle
        bV=v and math.clamp(v,0,95) or 0
        bT=bV>0 and xz/(bV*math.cos(ar)) or 0
    end

    bV=math.clamp(bV,0,95)
    qb_data.power=bV; qb_data.angle=bA; qb_data.airtime=bT; qb_data.targetPos=pred
    return bV,bA,bT,pred
end

