RunService.Heartbeat:Connect(function(dt)
    if not Hrp then return end
    if not magson then return end
    local ball=getfutbal(); if not ball then return end
    local cnp=tick()
    if magsdelayon and (cnp-lmgg)<magsdelay then return end
    local cp=catchPart(ball); if not cp then return end

    if magmode=="CFrame" then
        local dist=(ball.Position-cp.Position).Magnitude
        -- Ease-in curve: slow start (looks natural), fast finish
        -- Uses cubic ease: slow from far, fast near hands
        local t = math.clamp(dist / math.max(magsrange, 1), 0, 1)
        local ease = 1 - t*t*t  -- cubic ease-in, 0 when far, 1 when close
        local speed = 6 + ease * 18  -- 6 studs/s far, 24 studs/s close
        local alpha = math.clamp(dt * speed, 0, 0.92)
        -- Lerp position smoothly, keep ball's original rotation until very close
        if dist > 1.5 then
            -- Far: lerp only position, keep ball's existing rotation intact
            local newPos = ball.Position:Lerp(cp.Position, alpha)
            -- Extract rotation-only CFrame by rebuilding from components
            local rx,ry,rz,r00,r01,r02,r10,r11,r12,r20,r21,r22 = ball.CFrame:GetComponents()
            ball.CFrame = CFrame.new(newPos.X,newPos.Y,newPos.Z, r00,r01,r02,r10,r11,r12,r20,r21,r22)
        else
            -- Close: full CFrame snap into hands
            ball.CFrame = ball.CFrame:Lerp(cp.CFrame, alpha)
        end
    else
        if typeof(firetouchinterest)=="function" then
            pcall(firetouchinterest,ball,cp,0)
            task.wait()
            pcall(firetouchinterest,ball,cp,1)
        else
            local dist=(ball.Position-cp.Position).Magnitude
            local t=math.clamp(dist/math.max(magsrange,1),0,1)
            local ease=1-t*t*t
            local alpha=math.clamp(dt*(6+ease*18),0,0.92)
            ball.CFrame=ball.CFrame:Lerp(cp.CFrame,alpha)
        end
    end

    if magsdelayon then lmgg=cnp end
end)
