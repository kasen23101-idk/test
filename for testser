    if gpe then return end
    if input.KeyCode==Enum.KeyCode.Nine then aimbotActive=not aimbotActive; if aimbotActive then startAimbot() else stopAimbot() end end
    if input.KeyCode==Enum.KeyCode.RightShift then
        play(sndClick)
        frame.Visible=not frame.Visible
    end
end)
 
