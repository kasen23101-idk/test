    if _G.spamJump and lp.Character then local h=lp.Character:FindFirstChildOfClass("Humanoid"); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end end
    if _G.bhop and lp.Character then
        local h=lp.Character:FindFirstChildOfClass("Humanoid")
        if h and h:GetState()==Enum.HumanoidStateType.Landed then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)
lp.CharacterAdded:Connect(function(char)
    if flyActive then task.wait(1); startFly() end
    if _G.infJump then
        local h=char:WaitForChild("Humanoid")
        h.StateChanged:Connect(function(_,new) if new==Enum.HumanoidStateType.Freefall then h:SetStateEnabled(Enum.HumanoidStateType.Jumping,true) end end)
    end
end)
