local _uiTweening = false
local function toggleUI()
    if _uiTweening then return end
    _uiTweening = true
    local opening = not MainFrame.Visible
    if opening then
        MainFrame.Visible = true
        MainFrame.BackgroundTransparency = 1
        MainFrame.Size = UDim2.new(0, MainFrame.AbsoluteSize.X * 0.88, 0, MainFrame.AbsoluteSize.Y * 0.88)
        MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
        TS:Create(MainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0,
            Size = UDim2.new(0, 420, 0, 520)
        }):Play()
    else
        local tw = TS:Create(MainFrame, TweenInfo.new(0.13, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 420*0.90, 0, 520*0.90)
        })
        tw:Play()
        tw.Completed:Connect(function()
            MainFrame.Visible = false
            MainFrame.BackgroundTransparency = 0
            MainFrame.Size = UDim2.new(0, 420, 0, 520)
        end)
    end
    ToggleBtn.Text = opening and "Close" or "Kasen"
    task.delay(0.2, function() _uiTweening = false end)
end

local function unloadHub()
    -- Kill all feature flags
    qbEnabled=false; speedEnabled=false; magson=false; autocatchon=false
    ballpathOn=false; perfBeamEnabled=false; pullvector=false
    deleteOOBEnabled=false; jumpoweron=false; nojpcooldownon=false
    clicktackleon=false; tackleAimbotEnabled=false; tackleReachEnabled=false
    blockReachEnabled=false; kickerAutoEnabled=false; kickExtendEnabled=false
    antiLagEnabled=false; espEnabled=false

    -- Stop running loops/connections
    pcall(espStop)
    pcall(perfBeam_stop)
    pcall(stopMov)
    pcall(stopKE)
    if tAC then pcall(function() tAC:Disconnect() end) end

    -- Destroy world objects (beams, attachments, hitbox parts)
    pcall(function()
        for _,v in pairs(WS.Terrain:GetChildren()) do
            if (v:IsA("Beam")       and v.Name:find("Kasen"))
            or (v:IsA("Attachment") and v.Name:find("Kasen"))
            or (v:IsA("Beam")       and (v.Name=="PerfHitbox" or v.Name=="BallPath"))
            or (v:IsA("Attachment") and v.Name=="BallPathAtt") then
                v:Destroy()
            end
        end
    end)
    pcall(removeHitboxes)

    -- Destroy all hub GUI instances
    pcall(function() qb_beam.Enabled=false; qb_beam:Destroy() end)
    pcall(function() qbHL.Enabled=false;    qbHL:Destroy()    end)
    pcall(function() qba0:Destroy() end)
    pcall(function() qba1:Destroy() end)
    pcall(function() qb_gui:Destroy() end)
    pcall(function() ScreenGui:Destroy() end)   -- destroys MainFrame + ToggleBtn too

    print("[Kasen Hub] Unloaded.")
end


