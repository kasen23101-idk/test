local currentTab = nil
local function switchTab(name)
    if currentTab==name then return end
    for n,pg in pairs(tabPages) do
        pg.Visible = (n==name)
        if n==name then
            pg.Position=UDim2.new(0,0,0,98)
        end
    end
    for n,b in pairs(tabBtns) do
        local active=(n==name)
        b.BackgroundColor3 = active and Color3.fromRGB(88,62,200) or Color3.fromRGB(34,34,46)
        b.TextColor3 = active and Color3.fromRGB(255,255,255) or Color3.fromRGB(175,175,185)
    end
    currentTab=name
end

