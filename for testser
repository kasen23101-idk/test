local espEnabled = false
local espBills   = {}   -- [player] = BillboardGui

-- Sizing: mobile screens are smaller so we use bigger text (easier to read)
-- but shorter draw distance to keep it uncluttered
local ESP_MOB_TEXT  = 15   -- textsize on mobile
local ESP_PC_TEXT   = 13   -- textsize on PC
local ESP_MOB_DIST  = 180  -- studs, mobile (closer = less clutter on small screen)
local ESP_PC_DIST   = 350  -- studs, PC (wider FOV, more room)
local ESP_MOB_SIZE  = UDim2.new(0,90,0,26)   -- BillboardGui size mobile
local ESP_PC_SIZE   = UDim2.new(0,110,0,22)  -- BillboardGui size PC
local ESP_Y_OFFSET  = 3.2  -- studs above HRP

-- Team colours: try to read from team, fallback to white vs red
local function espColor(plr)
    if plr==Player then return Color3.fromRGB(80,220,80) end  -- self = green
    local tm=plr.Team; local myTm=Player.Team
    if tm and myTm then
        if tm==myTm then return Color3.fromRGB(80,180,255) end  -- teammate = blue
        return Color3.fromRGB(255,80,80)                        -- enemy = red
    end
    return Color3.fromRGB(255,255,255)
end

local function makeESPBill(plr)
    if espBills[plr] then return end
    local char=plr.Character; if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end

    local bill=Instance.new("BillboardGui")
    bill.Name="KasenESP"
    bill.Adornee=hrp
    bill.AlwaysOnTop=true
    bill.Size=isMobile and ESP_MOB_SIZE or ESP_PC_SIZE
    bill.StudsOffset=Vector3.new(0, ESP_Y_OFFSET, 0)
    bill.MaxDistance=isMobile and ESP_MOB_DIST or ESP_PC_DIST
    bill.ResetOnSpawn=false
    bill.Parent=CoreGui

    -- Name label
    local nameLbl=Instance.new("TextLabel",bill)
    nameLbl.Name="NameLbl"
    nameLbl.BackgroundTransparency=1
    nameLbl.Size=UDim2.new(1,0,0.65,0)
    nameLbl.Font=Enum.Font.GothamBold
    nameLbl.TextSize=isMobile and ESP_MOB_TEXT or ESP_PC_TEXT
    nameLbl.TextColor3=espColor(plr)
    nameLbl.TextStrokeTransparency=0.4
    nameLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    nameLbl.Text=plr.DisplayName~="" and plr.DisplayName or plr.Name
    nameLbl.TextScaled=false

    -- Distance label (below name)
    local distLbl=Instance.new("TextLabel",bill)
    distLbl.Name="DistLbl"
    distLbl.BackgroundTransparency=1
    distLbl.Position=UDim2.new(0,0,0.62,0)
    distLbl.Size=UDim2.new(1,0,0.38,0)
    distLbl.Font=Enum.Font.Gotham
    distLbl.TextSize=isMobile and (ESP_MOB_TEXT-4) or (ESP_PC_TEXT-3)
    distLbl.TextColor3=Color3.fromRGB(180,180,180)
    distLbl.TextStrokeTransparency=0.5
    distLbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
    distLbl.Text=""
    distLbl.TextScaled=false

    espBills[plr]={bill=bill, nameLbl=nameLbl, distLbl=distLbl}
end

local function removeESPBill(plr)
    local e=espBills[plr]
    if e then
        pcall(function() e.bill:Destroy() end)
        espBills[plr]=nil
    end
end

local function espClearAll()
    for plr,_ in pairs(espBills) do removeESPBill(plr) end
end

local function espRebuild()
    espClearAll()
    if not espEnabled then return end
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=Player then makeESPBill(plr) end
    end
end

-- Update distance labels every heartbeat, re-attach if char respawned
local espConn=nil
local function espStart()
    if espConn then return end
    espRebuild()
    -- When a new player joins, add their ESP
    Players.PlayerAdded:Connect(function(plr)
        if not espEnabled then return end
        plr.CharacterAdded:Connect(function()
            task.wait(0.5)
            removeESPBill(plr)
            if espEnabled then makeESPBill(plr) end
        end)
        task.wait(0.5)
        if espEnabled then makeESPBill(plr) end
    end)
    Players.PlayerRemoving:Connect(removeESPBill)
    -- Respawn handling for existing players
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=Player then
            plr.CharacterAdded:Connect(function()
                task.wait(0.5)
                removeESPBill(plr)
                if espEnabled then makeESPBill(plr) end
            end)
        end
    end
    espConn=RunService.Heartbeat:Connect(function()
        if not espEnabled then return end
        local myHrp=Hrp
        for plr,e in pairs(espBills) do
            if not plr.Parent then removeESPBill(plr); continue end
            local char=plr.Character
            local hrp=char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then
                -- char not loaded yet, skip
                e.bill.Enabled=false; continue
            end
            -- Re-adorn if character changed (respawn)
            if e.bill.Adornee~=hrp then e.bill.Adornee=hrp end
            e.bill.Enabled=true
            -- Update colour in case team changed
            e.nameLbl.TextColor3=espColor(plr)
            -- Distance
            if myHrp then
                local dist=math.floor((hrp.Position-myHrp.Position).Magnitude)
                e.distLbl.Text=dist.."st"
            end
        end
    end)
end

local function espStop()
    if espConn then espConn:Disconnect(); espConn=nil end
    espClearAll()
end

