    local function fmtTime(secondsLeft)
        if secondsLeft >= 86400*365*50 then return "Lifetime" end
        local d = math.floor(secondsLeft / 86400)
        local h = math.floor((secondsLeft % 86400) / 3600)
        if d > 0 then return d.."d "..h.."h remaining" end
        local m = math.floor((secondsLeft % 3600) / 60)
        return h.."h "..m.."m remaining"
    end

