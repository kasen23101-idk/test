    histN=0,   -- how many valid samples
}

-- Add a position sample to the ring buffer
local function qbHistPush(pos, t)
    local h=qb_data.hist
    table.insert(h,{pos=pos,t=t})
    if #h>QB_HIST_N then table.remove(h,1) end
    qb_data.histN=#h
end

-- Clear history (called when target switches)
local function qbHistClear()
    qb_data.hist={}
    qb_data.histN=0
end

-- Fit velocity + acceleration from position history using least-squares
-- Returns vel (Vector3), accel (Vector3)
-- Uses: pos(t) = pos0 + vel*t + 0.5*accel*t^2
local function qbFitMotion()
    local h=qb_data.hist
    local n=#h
    if n<3 then
        -- not enough history, fall back to smoothed vel
        return qb_data.smoothVel, Vector3.new()
    end

    -- Normalise time: t0 = most recent sample time
    local t0=h[n].t
    -- Build simple finite-difference estimates
    -- velocity: central diff between oldest and newest
    local dt_total = h[n].t - h[1].t
    if dt_total < 0.01 then return qb_data.smoothVel, Vector3.new() end

    local rawVel = (h[n].pos - h[1].pos) / dt_total

    -- Acceleration: compare velocity in first half vs second half
    local mid = math.floor(n/2)
    if mid<1 then return rawVel, Vector3.new() end

    local dt1 = h[mid].t - h[1].t
    local dt2 = h[n].t - h[mid].t
    if dt1<0.005 or dt2<0.005 then return rawVel, Vector3.new() end

    local v1 = (h[mid].pos - h[1].pos) / dt1
    local v2 = (h[n].pos - h[mid].pos) / dt2
    local avgDt = (dt1+dt2)*0.5
    local accel = (v2 - v1) / avgDt

    -- Clamp accel to prevent crazy extrapolation on lag spikes
    local aMax = 80
    if accel.Magnitude > aMax then
        accel = accel.Unit * aMax
    end

    -- Blend raw vel with smoothed vel (trust physics more when enough history)
    local blend = math.clamp((n-3)/(QB_HIST_N-3), 0, 1)
    local finalVel = qb_data.smoothVel:Lerp(rawVel, blend*0.7)

    return finalVel, accel
end

-- Predict receiver position t seconds in the future using fitted motion
local function qbPredictPos(t)
    local h=qb_data.hist
    local n=#h
    if n<1 then return qb_data.target and qb_data.target:FindFirstChild("HumanoidRootPart") and qb_data.target.HumanoidRootPart.Position or Vector3.new() end

    local vel, accel = qbFitMotion()
    local curPos = h[n].pos

    -- p(t) = curPos + vel*t + 0.5*accel*t^2
    local pred = curPos + vel*t + accel*(t*t*0.5)
    return pred, vel, accel
end
